# Server Configuration
PORT=3001
CLIENT_ORIGIN=http://localhost:3000

# Auth secrets — generate independently (e.g. `openssl rand -base64 64`).
# Use three distinct values in production: a single shared secret means a
# leak compromises sessions, CSRF protection, and JWTs simultaneously.
# SECRET (legacy) is accepted as a fallback for local dev only; the app
# logs a loud warning at boot if any of the three independent values is
# missing in production.
# Rotation: rotating JWT_SECRET invalidates outstanding JWTs (users re-login).
# Rotating SESSION_SECRET invalidates active sessions. Rotating CSRF_SECRET
# invalidates outstanding CSRF tokens.
JWT_SECRET=your_jwt_secret_here
SECRET=your_jwt_secret_here

# Database
DATABASE_URL=your_mongodb_connection_string

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=your_aws_region
S3_BUCKET_NAME=your_s3_bucket_name
# Protected bucket for sensitive documents (not publicly accessible)
# Used for travel documents, receipts, and other private files
S3_PROTECTED_BUCKET_NAME=your_protected_s3_bucket_name

# Google Maps API
# Used for interactive maps, geocoding, and address suggestions
# Backend: GOOGLE_MAPS_API_KEY
# Frontend (Vite): VITE_GOOGLE_MAPS_API_KEY
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# Twitter OAuth 2.0
TWITTER_CLIENT_ID=your_twitter_client_id
TWITTER_CLIENT_SECRET=your_twitter_client_secret
TWITTER_CALLBACK_URL=http://localhost:3001/api/auth/twitter/callback

# Facebook OAuth
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3001/api/auth/facebook/callback

# Session & CSRF Configuration
SESSION_SECRET=your_session_secret_here
CSRF_SECRET=your_csrf_secret_here

# Session Expiry Configuration
# Session expiry time in hours (default: 24)
# Sessions will expire after this many hours of inactivity
SESSION_EXPIRY_HOURS=24

# Plan Item Nesting Configuration
# Controls how deep plan items can be nested.
# Definition: root items have depth 0; a direct child has depth 1; etc.
# Default: 1 (allows one level of children, blocks child-of-child)
# Backend reads: PLAN_ITEM_MAX_NESTING_LEVEL
# Frontend (Vite) reads at build time: VITE_PLAN_ITEM_MAX_NESTING_LEVEL
PLAN_ITEM_MAX_NESTING_LEVEL=1
VITE_PLAN_ITEM_MAX_NESTING_LEVEL=1

# Email Configuration (Resend)
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=noreply@yourdomain.com
CLIENT_URL=http://localhost:3000

# Legal Contact Email (used in Terms, Privacy Policy, and Cookie Policy)
LEGAL_EMAIL_CONTACT=legal@yourdomain.com

# Node Environment
NODE_ENV=development

# Logging Configuration
# Frontend log level: ERROR, WARN, INFO, DEBUG, TRACE
# Default: ERROR in production, DEBUG in development
# Note: Using REACT_APP_ prefix for backward compatibility with Vite
REACT_APP_LOG_LEVEL=DEBUG

# Client-side obfuscation key (NOT cryptographic; just avoids plaintext-at-rest
# for small UI/session metadata in localStorage/sessionStorage).
# Frontend (Vite): exposed at build time.
# WARNING: Changing this will make previously stored obfuscated values unreadable.
VITE_BIEN_SECURE_STORAGE_LITE_SCRAMBLE_KEY=biensperience.secure-storage-lite.v1

# Backend log level (0-4): ERROR=0, WARN=1, INFO=2, DEBUG=3, TRACE=4
# Default: INFO (2)
LOG_LEVEL=2

# Backend logging destinations
LOG_CONSOLE=true         # Console logging (default: true)
LOG_FILE=false           # File logging (default: false)
LOG_FILE_PATH=./logs/backend.log
LOG_FORWARDER=false      # HTTP log forwarder (default: false)
LOG_FORWARDER_URL=       # URL for log forwarder
LOG_KAFKA=false          # Kafka logging (default: false)
KAFKA_BROKERS=           # Comma-separated list of Kafka brokers
KAFKA_TOPIC=biensperience-backend-logs

# Event Transport Configuration
# Transport type: 'localStorage' (default), 'websocket', or 'hybrid'
# - localStorage: Cross-tab sync via browser storage (no server required)
# - websocket: Real-time sync via WebSocket server
# - hybrid: Both localStorage and WebSocket for maximum reliability
REACT_APP_EVENT_TRANSPORT=localStorage

# WebSocket Configuration (client-side, required for 'websocket' or 'hybrid' transport)
REACT_APP_WEBSOCKET_URL=ws://localhost:3001/ws
REACT_APP_WEBSOCKET_RECONNECT_INTERVAL=3000
REACT_APP_WEBSOCKET_MAX_RECONNECT_ATTEMPTS=10

# WebSocket Server Configuration (server-side)
# Set to 'true' to enable the WebSocket server for real-time collaboration
WEBSOCKET_ENABLED=false
# WebSocket endpoint path (default: /ws)
WEBSOCKET_PATH=/ws

# AI Provider Configuration
# Default AI provider: openai, anthropic, mistral, gemini
AI_DEFAULT_PROVIDER=openai

# Provider API Keys (only configure the providers you want to use)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Task-Based Provider Routing (optional)
# Override the default provider for specific AI tasks
# Leave empty to use the default provider for all tasks
AI_AUTOCOMPLETE_PROVIDER=
AI_EDIT_PROVIDER=
AI_IMPROVE_PROVIDER=
AI_SUMMARIZE_PROVIDER=
AI_TIPS_PROVIDER=
AI_TRANSLATE_PROVIDER=

# Unsplash API (for BienBot photo suggestions)
# Get your access key at: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# TripAdvisor Content API v3 (for BienBot travel tips and POI data)
# Apply for a key at: https://developers.tripadvisor.com/
# NOTE: Free tier is non-commercial only. Commercial use requires a TripAdvisor
# partnership agreement. Leave blank to disable — BienBot will fall back to
# Google Maps and Wikivoyage data.
TRIPADVISOR_API_KEY=
# Daily call limit across all TripAdvisor API calls (default: 100)
# Each fetchTripAdvisorTips or fetchTripAdvisorPlaces call consumes up to 2 slots.
TRIPADVISOR_DAILY_LIMIT=100

# Currency Conversion Configuration
# API key for exchange rate service (required for open.er-api.com)
# Get your free API key at: https://www.exchangerate-api.com/
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here

# Primary exchange rate API URL (must include {base} placeholder, {apikey} is optional)
# Default: https://v6.exchangerate-api.com/v6/{apikey}/latest/{base}
EXCHANGE_RATE_API_URL=https://v6.exchangerate-api.com/v6/{apikey}/latest/{base}

# Fallback exchange rate API URL (used if primary fails)
# Default: https://api.exchangerate.host/latest?base={base}
EXCHANGE_RATE_FALLBACK_URL=https://api.exchangerate.host/latest?base={base}

# Exchange rate cache TTL in milliseconds
# Default: 3600000 (1 hour)
EXCHANGE_RATE_CACHE_TTL=3600000

# Stream Chat (Messaging)
# Backend uses server-side credentials. Never expose the secret to the frontend.
STREAM_CHAT_API_KEY=your_stream_chat_api_key
STREAM_CHAT_API_SECRET=your_stream_chat_api_secret

# Frontend (Vite) uses the public API key only
VITE_STREAM_CHAT_API_KEY=your_stream_chat_api_key

# BienBot AI Assistant Configuration
# Rate limiting: window in milliseconds and max requests per window
# Super admins bypass rate limiting regardless of these values
BIENBOT_RATE_LIMIT_WINDOW_MS=900000
BIENBOT_RATE_LIMIT_MAX=30

# Maximum length (characters) of a single user message
BIENBOT_MAX_MESSAGE_LENGTH=8000

# Token budget for context blocks injected into the LLM prompt
BIENBOT_CONTEXT_TOKEN_BUDGET=4000

# Number of recent conversation turns included in the LLM prompt
BIENBOT_HISTORY_TURNS=10

# Intent classifier AI provider and model overrides
# Leave empty to use the default AI provider (AI_DEFAULT_PROVIDER)
BIENBOT_CLASSIFIER_PROVIDER=
BIENBOT_CLASSIFIER_MODEL=

# Sinch Conversation API (Messaging)
# Backend-only. Never expose secrets to the frontend.
# Used by: utilities/sinch.js
SINCH_PROJECT_ID=your_sinch_project_id
SINCH_APP_ID=your_sinch_app_id
SINCH_KEY_ID=your_sinch_key_id
SINCH_KEY_SECRET=your_sinch_key_secret

# Optional: Sinch region for Conversation API base URL (default: us)
SINCH_REGION=us

# Optional (Application Authentication). Some Sinch products use application credentials.
# If you use multiple products with different credentials, you can set both sets.
SINCH_APPLICATION_KEY=
SINCH_APPLICATION_SECRET=

# Redis (optional - used for discovery cache; falls back to MongoDB if not set)
# REDIS_URL=redis://localhost:6379

# Content signals configuration (optional - JSON string, falls back to hardcoded defaults).
# Controls how trustScore, popularity, and recencyBoost are weighted during experience ranking.
# All numeric values are validated and sub-group weights are re-normalised to sum to 1 at startup.
#
# trustScore weights: how each attribute contributes to the 0-1 trust score.
#   curator        — creator has the 'curator' feature flag
#   public         — experience is publicly listed
#   completionRate — proxy from completed plan ratio
#   base           — floor score awarded to any experience with >= minPlanItems plans
#   minPlanItems   — minimum plan count to award the base score (integer)
#
# popularity weights: how the three raw plan-count dimensions blend into one 0-1 score.
#   planCount          — total distinct plans
#   planWithActivity   — plans with at least one activity_type plan item
#   completedPlans     — plans with at least one completed item
#
# reviews weights: placeholder for the future reviews dimension (accepted, not yet used).
#   avgRating — weight given to the normalised average rating
#
# formula: top-level blend between the adaptive collaborative score and the stored signals.
#   adaptiveFactor — share going to the existing adaptive/collaborative ranking
#   trustScore     — share going to the stored trustScore
#   popularity     — share going to the normalised popularity score
#   recencyBoost   — share going to the freshly-computed recency decay score
#   (values are re-normalised to sum to 1 at startup)
#
# SIGNALS_CONFIG='{"trustScore":{"curator":0.30,"public":0.20,"completionRate":0.20,"base":0.10,"minPlanItems":1},"popularity":{"planCount":0.50,"planWithActivity":0.30,"completedPlans":0.20},"reviews":{"avgRating":1.0},"formula":{"adaptiveFactor":0.70,"trustScore":0.10,"popularity":0.10,"recencyBoost":0.10}}'
