{
  "name": "biensperience",
  "version": "0.12.0",
  "description": "Biensperience: a visual travel experience planning platform (self-hostable)",
  "license": "AGPL-3.0-only",
  "author": "Goke Pelemo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gokepelemo/biensperience.git"
  },
  "bugs": {
    "url": "https://github.com/gokepelemo/biensperience/issues"
  },
  "homepage": "https://github.com/gokepelemo/biensperience#readme",
  "keywords": [
    "travel",
    "planning",
    "collaboration",
    "express",
    "mongoose",
    "vite",
    "self-hosted"
  ],
  "publishConfig": {
    "access": "public"
  },
  "private": false,
  "main": "./app.js",
  "exports": {
    ".": "./app.js"
  },
  "bin": {
    "biensperience": "./bin/biensperience.js"
  },
  "files": [
    "bin/",
    "build/",
    "!build/**/*.map",
    "config/",
    "controllers/",
    "models/",
    "public/",
    "routes/",
    "uploads/",
    "!uploads/documents/**",
    "!uploads/images/**",
    "!uploads/temp/**",
    "utilities/",
    "app.js",
    "server.js",
    "openapi.yaml",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@adobe/css-tools": "^4.4.4",
    "@anthropic-ai/sdk": "^0.71.2",
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.985.0",
    "@chakra-ui/react": "^3.34.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@floating-ui/react": "^0.27.17",
    "@fontsource/inter": "^5.2.8",
    "@google/generative-ai": "^0.24.1",
    "@googlemaps/js-api-loader": "^2.0.2",
    "@popperjs/core": "^2.11.8",
    "@react-google-maps/api": "^2.20.8",
    "@sinch/sdk-core": "^1.3.0",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@vitejs/plugin-react": "^5.1.3",
    "babel-preset-react-app": "^10.1.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.20.4",
    "connect-mongo": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-csrf": "^4.0.3",
    "cssnano": "^7.1.2",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "framer-motion": "^12.33.0",
    "helmet": "^8.1.0",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.11.0",
    "mongodb": "^7.1.0",
    "mongoose": "^7.8.9",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-nlp-rn": "^3.5.2",
    "nth-check": "^2.1.1",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
