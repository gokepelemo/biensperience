    "store2": "^2.14.4",
    "stream-chat": "^9.31.0",
    "stream-chat-react": "^13.13.6",
    "vite": "^7.3.1",
    "vite-plugin-env-compatible": "^2.0.1",
    "vite-plugin-svgr": "^4.5.0",
    "webpack-dev-server": "^5.2.3",
    "ws": "^8.19.0"
  },
  "overrides": {
    "js-yaml": ">=4.1.1"
  },
  "scripts": {
    "dev": "vite",
    "start": "node server.js",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "node scripts/ensure-build.js",
    "prepack": "node scripts/ensure-build.js",
    "test:api": "NODE_ENV=test jest --testPathPattern=tests/api",
    "test:api:debug": "DEBUG=true NODE_ENV=test jest --testPathPattern=tests/api --verbose",
    "test:api:watch": "NODE_ENV=test jest --testPathPattern=tests/api --watch",
    "test:api:coverage": "NODE_ENV=test jest --testPathPattern=tests/api --coverage",
    "test:frontend": "NODE_ENV=test jest --config=jest.config.frontend.js",
    "test:frontend:watch": "NODE_ENV=test jest --config=jest.config.frontend.js --watch",
    "test:frontend:coverage": "NODE_ENV=test jest --config=jest.config.frontend.js --coverage",
    "test:visual": "./tests/visual-regression/run-tests.sh",
    "test:visual:update": "./tests/visual-regression/run-tests.sh --update-baseline",
    "test:visual:modal": "npx playwright test tests/visual-regression/modal-comparison.spec.js",
    "test:visual:modal:update": "npx playwright test tests/visual-regression/modal-comparison.spec.js --update-snapshots",
    "test:visual:modal:report": "npx playwright show-report tests/visual-regression/report",
    "test:e2e": "./tests/e2e/run-modal-tests.sh",
    "test:e2e:headed": "./tests/e2e/run-modal-tests.sh --headed",
    "test:e2e:slow": "./tests/e2e/run-modal-tests.sh --slow",
    "test:email": "node utilities/test-email.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:delete": "pm2 delete ecosystem.config.js",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@storybook/addon-essentials": "^9.0.0-alpha.12",
    "@storybook/blocks": "^9.0.0-alpha.17",
    "@storybook/react-vite": "^9.1.17",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/dompurify": "^3.2.0",
    "@types/jest": "^30.0.0",
    "@types/supertest": "^6.0.3",
    "eslint-plugin-storybook": "^0.11.6",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^27.5.1",
    "mongodb-memory-server": "^10.4.3",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "postcss-mixins": "^12.1.2",
    "prop-types": "^15.8.1",
    "puppeteer": "^24.37.2",
    "storybook": "^9.1.17",
    "supertest": "^7.2.2",
    "webpack": "^5.105.0"
  }
}
